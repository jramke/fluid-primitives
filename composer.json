{
    "name": "jramke/fluid-primitives",
    "type": "typo3-cms-extension",
    "description": "The headless component library for TYPO3 Fluid",
    "license": "GPL-2.0-or-later",
    "version": "0.17.2",
    "authors": [
        {
            "name": "Joost Ramke",
            "role": "Developer",
            "email": "hey@joostramke.com",
            "homepage": "https://joostramke.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "typo3/cms-fluid": "^13.4 || ^14.1",
        "typo3fluid/fluid": "^4 || ^5"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "typo3/testing-framework": "^9.4"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "scripts": {
        "test": "pest",
        "prepare-release": [
            "rm -rf .github",
            "rm -f .gitignore",
            "rm -f .gitattributes",
            "rm -rf scripts",
            "rm -rf tests",
            "rm -f phpunit.xml",
            "rm -f tsconfig.json",
            "rm -f tsdown.config.ts",
            "rm -f package.json",
            "rm -f package-lock.json"
        ]
    },
    "autoload": {
        "psr-4": {
            "Jramke\\FluidPrimitives\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jramke\\FluidPrimitives\\Tests\\": "tests"
        }
    },
    "replace": {
        "typo3-ter/fluid_primitives": "*"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "fluid_primitives"
        }
    }
}
